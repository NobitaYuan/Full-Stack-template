{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "format": {},
    "test": {
      "dependsOn": ["build"]
    },
    "export-spec": {
      "outputs": ["openapi.json"]
    },
    "generate:api": {
      "dependsOn": ["@repo/server#export-spec"],
      "inputs": ["$TURBO_DEFAULT$", "../server/openapi.json"],
      "outputs": ["src/api/generated/**"]
    }
  }
}
